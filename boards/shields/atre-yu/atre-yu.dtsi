#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
        zmk,physical-layout = &atre_yu_physical_layout;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <10>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC(5,5) RC(5,4) RC(5,3) RC(5,2) RC(5,1) RC(5,0)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)  RC(6,5) RC(6,4) RC(6,3) RC(6,2) RC(6,1) RC(6,0)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)  RC(7,5) RC(7,4) RC(7,3) RC(7,2) RC(7,1) RC(7,0)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)  RC(8,5) RC(8,4) RC(8,3) RC(8,2) RC(8,1) RC(8,0)
                RC(4,2) RC(4,3) RC(4,4) RC(4,5)  RC(9,5) RC(9,4) RC(9,3) RC(9,2)
        >;
    };

    /*
     * Physical layout using ZMK's key_physical_attrs format.
     * Units are in 1/100 of 1U (where 1U = 19.05mm).
     * 6 columns left + 6 columns right, 4 main rows + 1 thumb row.
     * A 1U gap separates the two halves (left cols at x=0..500, right at x=700..1200).
     * Thumb row (y=420) is positioned ~4.2U below the top.
     */
    atre_yu_physical_layout: atre_yu_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Atre-yu";

        transform = <&default_transform>;

        keys //                     w   h    x    y   rot  rx  ry
            /* Row 0, Left */
            = <&key_physical_attrs 100 100    0   0    0    0   0>
            , <&key_physical_attrs 100 100  100   0    0    0   0>
            , <&key_physical_attrs 100 100  200   0    0    0   0>
            , <&key_physical_attrs 100 100  300   0    0    0   0>
            , <&key_physical_attrs 100 100  400   0    0    0   0>
            , <&key_physical_attrs 100 100  500   0    0    0   0>
            /* Row 0, Right */
            , <&key_physical_attrs 100 100  700   0    0    0   0>
            , <&key_physical_attrs 100 100  800   0    0    0   0>
            , <&key_physical_attrs 100 100  900   0    0    0   0>
            , <&key_physical_attrs 100 100 1000   0    0    0   0>
            , <&key_physical_attrs 100 100 1100   0    0    0   0>
            , <&key_physical_attrs 100 100 1200   0    0    0   0>
            /* Row 1, Left */
            , <&key_physical_attrs 100 100    0 100    0    0   0>
            , <&key_physical_attrs 100 100  100 100    0    0   0>
            , <&key_physical_attrs 100 100  200 100    0    0   0>
            , <&key_physical_attrs 100 100  300 100    0    0   0>
            , <&key_physical_attrs 100 100  400 100    0    0   0>
            , <&key_physical_attrs 100 100  500 100    0    0   0>
            /* Row 1, Right */
            , <&key_physical_attrs 100 100  700 100    0    0   0>
            , <&key_physical_attrs 100 100  800 100    0    0   0>
            , <&key_physical_attrs 100 100  900 100    0    0   0>
            , <&key_physical_attrs 100 100 1000 100    0    0   0>
            , <&key_physical_attrs 100 100 1100 100    0    0   0>
            , <&key_physical_attrs 100 100 1200 100    0    0   0>
            /* Row 2, Left */
            , <&key_physical_attrs 100 100    0 200    0    0   0>
            , <&key_physical_attrs 100 100  100 200    0    0   0>
            , <&key_physical_attrs 100 100  200 200    0    0   0>
            , <&key_physical_attrs 100 100  300 200    0    0   0>
            , <&key_physical_attrs 100 100  400 200    0    0   0>
            , <&key_physical_attrs 100 100  500 200    0    0   0>
            /* Row 2, Right */
            , <&key_physical_attrs 100 100  700 200    0    0   0>
            , <&key_physical_attrs 100 100  800 200    0    0   0>
            , <&key_physical_attrs 100 100  900 200    0    0   0>
            , <&key_physical_attrs 100 100 1000 200    0    0   0>
            , <&key_physical_attrs 100 100 1100 200    0    0   0>
            , <&key_physical_attrs 100 100 1200 200    0    0   0>
            /* Row 3, Left */
            , <&key_physical_attrs 100 100    0 300    0    0   0>
            , <&key_physical_attrs 100 100  100 300    0    0   0>
            , <&key_physical_attrs 100 100  200 300    0    0   0>
            , <&key_physical_attrs 100 100  300 300    0    0   0>
            , <&key_physical_attrs 100 100  400 300    0    0   0>
            , <&key_physical_attrs 100 100  500 300    0    0   0>
            /* Row 3, Right */
            , <&key_physical_attrs 100 100  700 300    0    0   0>
            , <&key_physical_attrs 100 100  800 300    0    0   0>
            , <&key_physical_attrs 100 100  900 300    0    0   0>
            , <&key_physical_attrs 100 100 1000 300    0    0   0>
            , <&key_physical_attrs 100 100 1100 300    0    0   0>
            , <&key_physical_attrs 100 100 1200 300    0    0   0>
            /* Thumb Row, Left */
            , <&key_physical_attrs 100 100  300 420    0    0   0>
            , <&key_physical_attrs 100 100  400 420    0    0   0>
            , <&key_physical_attrs 100 100  500 420    0    0   0>
            , <&key_physical_attrs 100 100  600 420    0    0   0>
            /* Thumb Row, Right */
            , <&key_physical_attrs 100 100  700 420    0    0   0>
            , <&key_physical_attrs 100 100  800 420    0    0   0>
            , <&key_physical_attrs 100 100  900 420    0    0   0>
            , <&key_physical_attrs 100 100 1000 420    0    0   0>
            ;
    };

    left_encoder: encoder_left {
        compatible = "alps,ec11";
        a-gpios = <&gpio1 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio1 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "disabled";
    };

    right_encoder: encoder_right {
        compatible = "alps,ec11";
        a-gpios = <&gpio1 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio1 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder &right_encoder>;
        triggers-per-rotation = <20>;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;
    };
};
