/zmk,physical-layout = {
    compatible = "zmk,physical-layout";
    width = <12 * 19.05>;  // Width in mm
    height = <4 * 19.05>; // Height in mm
    thumb-key-rows = <8>;  // Additional thumb keys
    /* Define the coordinate mapping */
    coordinates = <   
        /* x      y */
        0,     0,    // Key 0
        19.05, 0,    // Key 1
        38.1,  0,    // Key 2
        57.15, 0,    // Key 3
        76.2,  0,    // Key 4
        95.25, 0,    // Key 5
        114.3, 0,   // Key 6
        133.35,0,    // Key 7
        152.4,  0,    // Key 8
        0,     19.05,// Key 9
        19.05, 19.05,// Key 10
        38.1,  19.05,// Key 11
        57.15, 19.05,// Key 12
        76.2,  19.05,// Key 13
        95.25, 19.05,// Key 14
        114.3, 19.05,// Key 15
        133.35,19.05,// Key 16
        152.4,  19.05,// Key 17
        0,     38.1,  // Key 18
        19.05, 38.1,  // Key 19
        38.1,  38.1,  // Key 20
        57.15, 38.1,  // Key 21
        76.2,  38.1,  // Key 22
        95.25, 38.1,  // Key 23
        114.3, 38.1,  // Key 24
        133.35,38.1,  // Key 25
        152.4,  38.1,  // Key 26
        0,     57.15, // Key 27
        19.05, 57.15, // Key 28
        38.1,  57.15, // Key 29
        57.15, 57.15, // Key 30
        76.2,  57.15, // Key 31
        95.25, 57.15, // Key 32
        114.3, 57.15, // Key 33
        133.35,57.15, // Key 34
        152.4,  57.15  // Key 35
    >;
};

