#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;

        /* Ensure the matrix transform below is exported as the default transform */
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <10>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,4) RC(5,5)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)  RC(6,0) RC(6,1) RC(6,2) RC(6,3) RC(6,4) RC(6,5)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)  RC(7,0) RC(7,1) RC(7,2) RC(7,3) RC(7,4) RC(7,5)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)  RC(8,0) RC(8,1) RC(8,2) RC(8,3) RC(8,4) RC(8,5)
                RC(3,3) RC(4,3) RC(4,4) RC(4,5)  RC(9,0) RC(9,1) RC(9,2) RC(9,3)
        >;
    };

    /*
     * Physical layout in millimeters.
     * Assumptions:
     * - 1U spacing = 19.05mm
     * - 12 keys wide (6 left + 6 right) for the 4 main rows
     * - thumb row is 8 keys in a line (4 left + 4 right)
     *
     * You can later tweak x/y values for stagger/angle while keeping the same ordering.
     */
    atre_yu_physical_layout: atre_yu_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Atre-yu";

        /* tie layout to the transform */
        transform = <&default_transform>;

        keys = <
            /* Main grid: 12 columns x 4 rows */
            /* row 0 */
            0 0   0.00   0.00   1 0  19.05   0.00   2 0  38.10   0.00   3 0  57.15   0.00   4 0  76.20   0.00   5 0  95.25   0.00
            6 0 133.35   0.00   7 0 152.40   0.00   8 0 171.45   0.00   9 0 190.50   0.00  10 0 209.55   0.00  11 0 228.60   0.00

            /* row 1 */
            0 1   0.00  19.05   1 1  19.05  19.05   2 1  38.10  19.05   3 1  57.15  19.05   4 1  76.20  19.05   5 1  95.25  19.05
            6 1 133.35  19.05   7 1 152.40  19.05   8 1 171.45  19.05   9 1 190.50  19.05  10 1 209.55  19.05  11 1 228.60  19.05

            /* row 2 */
            0 2   0.00  38.10   1 2  19.05  38.10   2 2  38.10  38.10   3 2  57.15  38.10   4 2  76.20  38.10   5 2  95.25  38.10
            6 2 133.35  38.10   7 2 152.40  38.10   8 2 171.45  38.10   9 2 190.50  38.10  10 2 209.55  38.10  11 2 228.60  38.10

            /* row 3 */
            0 3   0.00  57.15   1 3  19.05  57.15   2 3  38.10  57.15   3 3  57.15  57.15   4 3  76.20  57.15   5 3  95.25  57.15
            6 3 133.35  57.15   7 3 152.40  57.15   8 3 171.45  57.15   9 3 190.50  57.15  10 3 209.55  57.15  11 3 228.60  57.15

            /*
             * Thumb row: 8 keys (4 left + 4 right) in a straight line.
             * Positioned one "row" below, centered-ish between halves.
             */
            0 4  57.15  80.00   1 4  76.20  80.00   2 4  95.25  80.00   3 4 114.30  80.00
            4 4 133.35  80.00   5 4 152.40  80.00   6 4 171.45  80.00   7 4 190.50  80.00
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
    };
};
